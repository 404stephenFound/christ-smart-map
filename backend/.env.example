# ============================================================
# ChristSmart Cabin Finder — Backend Environment Configuration
# ============================================================
# INSTRUCTIONS FOR NEW DEVELOPERS:
# 1. Copy this file and rename it to: .env
# 2. Fill in YOUR own values below
# 3. NEVER commit the actual .env file (it is gitignored)
# ============================================================

# ----------------------------------------------------------
# PostgreSQL Database Connection
# Change username/password/port to match YOUR local Postgres
# The database "cabin_finder" will be auto-created on startup
# ----------------------------------------------------------
DATABASE_URL="postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/cabin_finder?schema=public"

# ----------------------------------------------------------
# JWT Secret Key
# Any long random string — used to sign login tokens
# Example: openssl rand -base64 32
# ----------------------------------------------------------
JWT_SECRET="replace-with-your-own-long-random-secret-key"

# ----------------------------------------------------------
# Server Port
# The port Express will listen on
# ----------------------------------------------------------
PORT=5000

# ----------------------------------------------------------
# Faculty Registration Passcode
# IMPORTANT: Get this value from the project owner privately
# (via WhatsApp / direct message — never put the real value here)
# ----------------------------------------------------------
REGISTRATION_SECRET="ask-project-owner-for-this-value"

# ----------------------------------------------------------
# Allowed Email Domain for Faculty Registration
# Only emails ending with this domain can register
# ----------------------------------------------------------
ALLOWED_EMAIL_DOMAIN="@christuniversity.in"
